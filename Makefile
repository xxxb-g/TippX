.phony: build
build:
	python3 -m nuitka --onefile --include-module="random" --include-module="pygame" --product-name=TippX_by_xxxb --output-filename="TippX" --nofollow-import-to=unittest --nofollow-import-to=numpy --nofollow-import-to=pygame.surfarray --nofollow-import-to=pygame.sndarray --nofollow-import-to=pygame.image --nofollow-import-to=pygame.transform --nofollow-import-to=libssl --include-data-files=Ding.mp3=. --include-data-files=Doeng.mp3=. --include-data-file=LICENSE=. main.py
windoof_build:
	python3 -m pyinstaller -n TippX.exe --add-data Ding.mp3:. --add-data Doeng.mp3:. --add-data LICENSE:. --hidden-import pygame --hidden-import random --exclude-module unittest --exclude-module numpy --exclude-module pygame.surfarray --exclude-module pygame.sndarray --exclude-module pygame.image --exclude-module pygame.transform --exclude-module libssl --optimize 2 -F main.py